      "Grok 3 Mini": "grok-3-mini",
      "Grok 2": "grok-2-1212",
      "Grok 4-1": "grok-4-1-fast-reasoning"
    }
  },
  {
    "provider": "OpenAI",
    "baseurl": "https://api.openai.com/v1",
    "env_key": "OPENAI_API_KEY",
    "models": {
      "GPT-4o": "gpt-4o",
      "GPT-4o Mini": "gpt-4o-mini",
      "GPT-5 nano": "gpt-5-nano"
    }
  }
]
